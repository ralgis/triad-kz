includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6

    paths:
        - app/
        - config/
        - database/
        - routes/
        - tests/

    excludePaths:
        - vendor/*
        - storage/*
        - bootstrap/cache/*

    # Larastan understands Eloquent magic, but PHPStan still wants explicit
    # generic type annotations on every BelongsTo/HasMany/HasFactory. Annotating
    # 30+ relations across 10 models is more noise than signal — we suppress the
    # warning globally and let Larastan handle the runtime correctness.
    #
    # method.alreadyNarrowedType is also suppressed because PHPStan sometimes
    # flags admin-form callbacks where the narrowing is intentional defensive
    # programming, not actually redundant.
    ignoreErrors:
        - identifier: missingType.generics
        - identifier: method.alreadyNarrowedType
        # Laravel Eloquent magic — property access through __get isn't visible
        # to PHPStan without @property annotations on every model. We accept
        # this trade-off; real typos are caught at runtime by tests.
        - identifier: property.notFound
        # Defensive null-checks on optional Factory inputs are intentional.
        - identifier: nullsafe.neverNull
        # Laravel-generated UserFactory return-type doesn't match Larastan's
        # narrowed array<model property,mixed> — Laravel default, not our code.
        - identifier: method.childReturnType

    # Don't fail when an ignore-pattern stops matching (e.g. we fixed an
    # error and the suppressor became unused). Avoids noise on cleanup PRs.
    reportUnmatchedIgnoredErrors: false

    # Postpone level 8 until project stabilizes (Phase 3). Goal is level 8.
    checkOctaneCompatibility: true
    checkModelProperties: true
