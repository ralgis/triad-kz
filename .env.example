# ─── triad-kz .env.example ────────────────────────────────────────────────
# This file is committed to git as a TEMPLATE. The real .env lives ONLY on
# disk (gitignored), never in the repo.
#
# Production .env should be created on the server (Plesk → File Manager →
# dev.triad.kz/.env) — NOT in dev.triad.kz/public/.env. Use this file as
# the starting point.
# ──────────────────────────────────────────────────────────────────────────

APP_NAME="ТРИ АД Construction"
APP_ENV=local
# Generate once: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────
# Local dev: SQLite (zero-config, file at database/database.sqlite).
# Production (dev.triad.kz, triad.kz): MySQL / MariaDB via Plesk.
#
# Plesk creates DB + user pair and gives you these four values:
#   DB_DATABASE=triadkz_dev
#   DB_USERNAME=triadkz_dev
#   DB_PASSWORD=<copy from Plesk>
#   DB_HOST=localhost  (default for Plesk)
DB_CONNECTION=sqlite
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=triadkz_dev
# DB_USERNAME=triadkz_dev
# DB_PASSWORD=

# ─── Session / Cache / Queue ──────────────────────────────────────────────
# All three use the DB (no redis on Plesk by default).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true   # set false only for plain-http local dev

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─── Mail ─────────────────────────────────────────────────────────────────
# Local dev: log driver (no real mail sent, see storage/logs/laravel.log).
# Production (Plesk): use Plesk's local mail relay
#   MAIL_MAILER=smtp
#   MAIL_HOST=localhost
#   MAIL_PORT=25
#   MAIL_USERNAME=
#   MAIL_PASSWORD=
#   MAIL_ENCRYPTION=null
#   MAIL_FROM_ADDRESS=no-reply@triad.kz
#   MAIL_FROM_NAME="ТРИ АД Construction"
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@triad.kz"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Triad-specific ───────────────────────────────────────────────────────
# Email-получатель заявок с сайта. Read by Setting::current().
# Override per-environment if needed (staging/prod can differ).
TRIAD_INQUIRY_EMAIL=ravacom@mail.ru
