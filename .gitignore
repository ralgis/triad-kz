*.log
.DS_Store
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
/.codex
/.cursor/
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
/node_modules
# /public/build  ← KEPT IN GIT: Plesk has no Node.js, so we commit
#                  Vite-built assets. Rebuild locally with `npm run build`
#                  before pushing. CI doesn't run npm build.
/public/fonts-manifest.dev.json
/public/hot
/public/storage
/storage/*.key
/storage/pail
/storage/app/invoices/
# /vendor  ← KEPT IN GIT: Plesk shared hosting disables `proc_open`, so
#             `composer install` cannot run on the server. We pre-build
#             vendor/ locally and ship it with the repo. Rebuild locally
#             via `composer install --no-dev --optimize-autoloader`
#             before each push that changes dependencies.

# Local SQLite — each dev runs `php artisan migrate` fresh
/database/*.sqlite
/database/*.sqlite-journal
/database/*.sqlite-wal
/database/*.sqlite-shm
_ide_helper.php
Homestead.json
Homestead.yaml
Thumbs.db

# Project-specific: legacy reference material — never push
/_legacy/

# Plan + task docs from Claude planning sessions (kept locally for context)
/план_работ_*

# OS / editors
*.swp
*.swo
*~
.directory

# Local-only test artifacts
/coverage/
.phpunit.cache/
